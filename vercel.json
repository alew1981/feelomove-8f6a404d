{
  "headers": [
    {
      "source": "/en/(.*)",
      "headers": [
        { "key": "Content-Language", "value": "en" },
        { "key": "Vary", "value": "Accept-Language" }
      ]
    },
    {
      "source": "/((?!en/).*)",
      "headers": [
        { "key": "Content-Language", "value": "es" }
      ]
    }
  ],
  "redirects": [
    { "source": "/concierto/:slug", "destination": "/conciertos/:slug", "permanent": true },
    { "source": "/producto/:slug", "destination": "/conciertos/:slug", "permanent": true },
    { "source": "/festival/:slug", "destination": "/festivales/:slug", "permanent": true },
    { "source": "/generos/:slug", "destination": "/musica/:slug", "permanent": true },
    { "source": "/generos", "destination": "/musica", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=index" },
    { "source": "/sitemap_index.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=index" },
    { "source": "/sitemap-pages.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=pages" },
    { "source": "/sitemap-concerts.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=concerts" },
    { "source": "/sitemap-festivals.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=festivals" },
    { "source": "/sitemap-artists.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=artists" },
    { "source": "/sitemap-destinations.xml", "destination": "https://wcyjuytpxxqailtixept.supabase.co/functions/v1/sitemap?type=destinations" },
    { "source": "/en/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
